{
  "name": "rally",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "2D top-down rally racing game with arcade drifting, procedural tracks, multiple surfaces, and free-for-all multiplayer.",
  "scripts": {
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "dev": "concurrently -k -n server,client -c green,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "build:client": "vite build",
    "start": "tsx src/server/index.ts",
    "test": "vitest run",
    "test:visual": "vitest run --config vitest.visual.config.ts",
    "smoke": "node scripts/smoke-e2e.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@colyseus/core": "^0.16",
    "@colyseus/schema": "^3",
    "@colyseus/ws-transport": "^0.16",
    "colyseus": "^0.16",
    "colyseus.js": "^0.16",
    "express": "^4",
    "phaser": "^3.88"
  },
  "devDependencies": {
    "@colyseus/testing": "^0.16",
    "@napi-rs/canvas": "^0.1",
    "@types/express": "^4",
    "@types/node": "^22",
    "concurrently": "^9",
    "puppeteer-core": "^23",
    "tsx": "^4",
    "typescript": "^5",
    "vite": "^5",
    "vitest": "^2"
  }
}
